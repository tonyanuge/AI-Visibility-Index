# === Optional live engine runners (automated prompt fetch). Leave blank to run manual-only. ===
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=
# === Optional email connector (lead report delivery) ===
SENDGRID_API_KEY=
# === Admin lead export ===
# Required to enable GET /api/leads/export (returns lead emails — PII). Leave blank and
# export is disabled (fails closed). Set a long random secret, then send it on requests
# via the X-Admin-Export-Token header. Never put this token in frontend code.
AVIX_ADMIN_EXPORT_TOKEN=
